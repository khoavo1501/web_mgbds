# Copy this file to .env and fill in your Cloudinary credentials.
# Keep .env private. Do not commit real secrets.

# local = save images to backend/images
# cloudinary = upload images to Cloudinary
UPLOAD_PROVIDER=local

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=mgbds/properties
